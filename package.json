{
  "name": "@lonewolfyx/vue-hooks",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "description": "lonewolfyx's Collection of Vue Composition Utilities",
  "author": "lonewolfyx",
  "license": "MIT",
  "homepage": "https://github.com/lonewolfyx/vue-hooks",
  "bugs": {
    "url": "https://github.com/lonewolfyx/vue-hooks/issues"
  },
  "keywords": [
    "vue",
    "hooks"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "prepublishOnly": "pnpm build",
    "prepare": "simple-git-hooks",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@lonewolfyx/tsconfig": "^0.0.6",
    "@types/node": "^25.7.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "nano-staged": "^1.0.2",
    "picocolors": "^1.1.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged",
    "commit-msg": "node scripts/verify-commit.js"
  },
  "nano-staged": {
    "*": "eslint --fix"
  }
}